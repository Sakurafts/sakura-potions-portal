---
import fs from 'node:fs';
import path from 'node:path';
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import BrandLogo from '../components/BrandLogo.astro';

// Get Lab Logs
const allDocs = await getCollection('docs');
const labLogs = allDocs
  .filter(doc => doc.data.category === 'Lab Logs')
  .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

// Pantry Questのロゴ画像の有無をチェック
const pqPngPath = path.join(process.cwd(), 'public', 'pantry-quest-logo.png');
const pqJpgPath = path.join(process.cwd(), 'public', 'pantry-quest-logo.jpg');
const hasPqLogo = fs.existsSync(pqPngPath) || fs.existsSync(pqJpgPath);
const pqLogoSrc = fs.existsSync(pqPngPath) ? '/pantry-quest-logo.png' : '/pantry-quest-logo.jpg';
---

<BaseLayout title="ホーム">
  <div class="flex flex-col items-center justify-center pt-20 pb-10 text-center">
    <BrandLogo size="lg" />
    <h1 class="text-4xl md:text-5xl font-extrabold text-sakura-900 tracking-tight mb-6">
      Sakura Potions <span class="text-sakura-400">Portal</span>
    </h1>
    <p class="text-xl text-gray-600 max-w-2xl leading-relaxed">
      <span class="inline-block">「日常の『痒い所』に手が届く、</span><span class="inline-block">ちゃめっ気あふれる解決策の集積地」へようこそ。</span><br class="hidden md:block">
      <span class="inline-block">私たちが開発したツールのマニュアルや、</span><span class="inline-block">裏側の技術スタックを公開しています。</span>
    </p>

  </div>

  <div class="mt-8 w-full">
    <h2 class="text-2xl font-bold text-center text-sakura-800 mb-8">注目のプロジェクト</h2>
    <div class="flex overflow-x-auto pb-8 snap-x snap-mandatory md:grid md:grid-cols-2 gap-8 -mx-4 px-4 md:mx-0 md:px-0 scrollbar-hide">
      <!-- Pantry Quest Project Card -->
      <a href="/pantry-quest" class="block group shrink-0 w-[85vw] md:w-auto snap-center">
        <div class="bg-white rounded-3xl p-8 border-2 border-transparent hover:border-sakura-200 shadow-sm hover:shadow-xl transition-all duration-300">
          {hasPqLogo ? (
            <img src={pqLogoSrc} alt="Pantry Quest Logo" class="w-16 h-16 rounded-2xl object-cover mb-6 shadow-sm border border-gray-100" />
          ) : (
            <div class="w-16 h-16 bg-orange-100 text-orange-500 rounded-2xl flex items-center justify-center text-3xl mb-6">
              🍱
            </div>
          )}
          <h3 class="text-2xl font-bold text-gray-900 mb-3 group-hover:text-sakura-600 transition-colors">
            Pantry Quest
          </h3>
          <p class="text-gray-600 mb-4 text-sm leading-relaxed">
            <span class="inline-block">複数人での食材管理の</span><span class="inline-block">お悩みにフォーカスした、</span><!--
            --><span class="inline-block">なるべく頭を使わない</span><span class="inline-block">AI在庫管理アプリ。</span>
            <span class="inline-block">リスト共有で「重複購入」を防ぎ、</span><!--
            --><span class="inline-block">メッセージタグで「これ食べていい？」の</span><span class="inline-block">すれ違いを解消！</span>
            <span class="inline-block">使うたびに貯まるExpで</span><span class="inline-block">モチベーションをキープできます。</span>
          </p>
          <span class="text-sakura-500 font-medium group-hover:underline underline-offset-4">プロジェクト詳細を見る &rarr;</span>
        </div>
      </a>

      <!-- Future Project Placeholder -->
      <div class="bg-gray-50 rounded-3xl p-8 border-2 border-dashed border-gray-200 flex flex-col items-center justify-center text-center opacity-70 shrink-0 w-[85vw] md:w-auto snap-center">
        <div class="w-16 h-16 bg-gray-200 text-gray-400 rounded-2xl flex items-center justify-center text-3xl mb-4">
          ✨
        </div>
        <h3 class="text-xl font-bold text-gray-400 mb-2">Coming Soon...</h3>
        <p class="text-gray-400 text-sm">
          新しい「ちゃめっ気」あふれるツールを鋭意開発中です。
        </p>
      </div>
    </div>
  </div>

  <!-- Lab Logs Section -->
  <div class="mt-20 w-full mb-16">
    <div class="flex flex-col items-center mb-8">
      <h2 class="text-2xl font-bold text-sakura-800 flex items-center gap-2">
        <svg class="w-6 h-6 text-sakura-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z"></path>
        </svg>
        Lab Logs (実験記録)
      </h2>
      <p class="text-gray-500 text-sm mt-2 text-center max-w-2xl">
        私自身がこのプロジェクトを始めようと思った経緯や、まだ「Potion（魔法の薬）」の調合が終わっていない未完成な日々の悩みなど、等身大の気づきをつらつらと書き留めていく実験記録です。
      </p>
    </div>

    <div class="flex overflow-x-auto pb-6 snap-x snap-mandatory md:grid md:grid-cols-2 gap-6 -mx-4 px-4 md:mx-0 md:px-0 scrollbar-hide">
      {labLogs.map(log => (
        <a href={`/docs/${log.id}`} class="block group shrink-0 w-[85vw] md:w-auto snap-center">
          <article class="bg-white p-6 rounded-2xl shadow-sm border border-sakura-100 hover:border-sakura-300 hover:shadow-md transition-all duration-300 h-full flex flex-col justify-between">
            <div>
              <div class="flex justify-between items-start mb-2">
                <span class="inline-block px-2 py-1 bg-gray-100 text-gray-600 text-xs font-semibold rounded">
                  {log.data.date ? new Date(log.data.date).toLocaleDateString('ja-JP') : 'Recent'}
                </span>
              </div>
              <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-sakura-600 transition-colors">
                {log.data.title}
              </h3>
              {log.data.description && (
                <p class="text-gray-600 text-sm line-clamp-2">
                  {log.data.description}
                </p>
              )}
            </div>
            <div class="mt-4 flex items-center text-sm font-medium text-sakura-500 group-hover:text-sakura-600">
              記録を読む
              <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </article>
        </a>
      ))}
      <div class="bg-gray-50 rounded-2xl p-6 border-2 border-dashed border-gray-200 flex flex-col items-center justify-center text-center opacity-70 min-h-[160px] shrink-0 w-[85vw] md:w-auto snap-center">
        <div class="text-gray-400 mb-2">
          <svg class="w-8 h-8 mx-auto" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path></svg>
        </div>
        <p class="text-gray-500 text-sm font-medium">次の実験記録を準備中です...</p>
      </div>
    </div>
  </div>
</BaseLayout>
