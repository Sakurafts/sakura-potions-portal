---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import fs from 'node:fs';
import path from 'node:path';

// Get Pantry Quest docs
const allDocs = await getCollection('docs');
const pqDocs = allDocs.filter(doc => doc.data.category === 'Pantry Quest');

const featureDocs = pqDocs
  .filter(doc => !doc.data.title.includes('リリースノート'))
  .sort((a, b) => a.data.order - b.data.order);

const releaseDocs = pqDocs
  .filter(doc => doc.data.title.includes('リリースノート'))
  .sort((a, b) => b.data.order - a.data.order);

// Check logo
const pqPngPath = path.join(process.cwd(), 'public', 'pantry-quest-logo.png');
const pqJpgPath = path.join(process.cwd(), 'public', 'pantry-quest-logo.jpg');
const hasPqLogo = fs.existsSync(pqPngPath) || fs.existsSync(pqJpgPath);
const pqLogoSrc = fs.existsSync(pqPngPath) ? '/pantry-quest-logo.png' : '/pantry-quest-logo.jpg';
---

<BaseLayout title="Pantry Quest - プロジェクト詳細">
  <Breadcrumbs items={[{ label: 'Pantry Quest' }]} />

  <div class="max-w-4xl mx-auto">
    <!-- Hero Section -->
    <div class="bg-white rounded-3xl p-8 md:p-12 shadow-sm border border-sakura-100 mb-10 text-center">
      <div class="flex justify-center mb-6">
        {hasPqLogo ? (
          <img src={pqLogoSrc} alt="Pantry Quest Logo" class="w-24 h-24 rounded-3xl object-cover shadow-md border border-gray-100" />
        ) : (
          <div class="w-24 h-24 bg-orange-100 text-orange-500 rounded-3xl flex items-center justify-center text-4xl shadow-sm border border-gray-100">
            🍱
          </div>
        )}
      </div>
      <h1 class="text-4xl md:text-5xl font-extrabold text-gray-900 tracking-tight mb-4">
        Pantry Quest
      </h1>
      <p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto mb-8 leading-relaxed">
        複数人での食材管理のお悩みにフォーカスした、<br />
        なるべく頭を使わないAI在庫管理アプリ。
        <span class="block mt-4">
          リスト共有で「重複購入」を防ぎ、<br class="hidden md:inline" />
          メッセージタグで「これ食べていい？」のすれ違いを解消！<br />
          使うたびに貯まるExpでモチベーションをキープできます。
        </span>
      </p>
      
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="https://pantry-quest.sakurapotions.com/" target="_blank" rel="noopener noreferrer" class="bg-sakura-500 hover:bg-sakura-600 text-white font-bold py-3 px-8 rounded-full shadow-md hover:shadow-lg transition-all transform hover:-translate-y-1 flex items-center justify-center gap-2">
          アプリを開く
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path>
          </svg>
        </a>
      </div>
    </div>


    <!-- Release Notes Section -->
    <h2 class="text-2xl font-bold text-sakura-900 mb-6 flex items-center gap-2">
      <svg class="w-6 h-6 text-sakura-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
      </svg>
      リリースノート（更新履歴）
    </h2>

    <div class="grid grid-cols-1 gap-4 pb-12">
      {releaseDocs.map(doc => (
        <a href={`/docs/${doc.id}`} class="block group">
          <article class="bg-white p-5 rounded-2xl shadow-sm border border-sakura-100 hover:border-sakura-300 hover:shadow-md transition-all duration-300 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
            <div>
              <h3 class="text-lg font-bold text-gray-900 group-hover:text-sakura-600 transition-colors">
                {doc.data.title}
              </h3>
              {doc.data.description && (
                <p class="text-gray-600 text-sm mt-1 line-clamp-1">
                  {doc.data.description}
                </p>
              )}
            </div>
            <div class="flex items-center text-sm font-medium text-sakura-500 group-hover:text-sakura-600 shrink-0">
              詳細を見る
              <svg class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </article>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
