---
import BaseLayout from './BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

const { frontmatter } = Astro.props;
---

<BaseLayout title={frontmatter.title} description={frontmatter.description}>
  <Breadcrumbs items={[{ label: frontmatter.title }]} />
  
  <article class="prose prose-sakura max-w-none bg-white p-8 rounded-2xl shadow-sm border border-sakura-100 mb-8">
    <h1 class="text-3xl font-bold text-sakura-900 mb-6">{frontmatter.title}</h1>
    
    <div class="md-content text-gray-700">
      <slot />
    </div>
  </article>
</BaseLayout>

<style is:global>
  /* Custom prose overrides for standard Markdown pages */
  .md-content h2 { margin-top: 2em; margin-bottom: 1em; color: var(--color-sakura-800); border-bottom: 2px solid var(--color-sakura-100); padding-bottom: 0.3em; font-size: 1.5rem; font-weight: bold; }
  .md-content h3 { margin-top: 1.5em; margin-bottom: 0.75em; color: var(--color-sakura-700); font-size: 1.25rem; font-weight: bold; }
  .md-content p { margin-bottom: 1.25em; line-height: 1.7; }
  .md-content ul { list-style-type: disc; padding-left: 1.5em; margin-bottom: 1.25em; }
  .md-content ol { list-style-type: decimal; padding-left: 1.5em; margin-bottom: 1.25em; }
  .md-content li { margin-bottom: 0.5em; }
  .md-content a { color: var(--color-sakura-600); text-decoration: underline; text-decoration-thickness: 1px; text-underline-offset: 4px; transition: color 0.2s; }
  .md-content a:hover { color: var(--color-sakura-800); text-decoration-thickness: 2px; }
  .md-content strong { font-weight: 600; color: var(--color-gray-900); }
</style>
